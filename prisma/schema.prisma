generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Waitlist {
  id         Int      @id @default(autoincrement())
  firstName  String   @map("first_name")
  email      String
  area       String
  activities String
  createdAt  DateTime @default(now()) @map("created_at")

  @@map("waitlist")
}
